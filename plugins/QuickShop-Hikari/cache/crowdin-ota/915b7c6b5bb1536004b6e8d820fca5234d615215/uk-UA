    commands:
      discount:
        description: <yellow>Застосувати код знижки або керувати вашими кодами знижок.
    tab-complete:
      discount:
        general:
          code: \<code>
        create:
          rate: |
            Підказка команди:
            Аргумент: \<rate>
            Опис: Фактичний відсоток або гроші, які ви заробите
            Введіть `30%` = ціна * 0,3
            Введіть `50` = ціна - 50
          max-usage: |
            Підказка команди:
            Аргумент: [max-usage]
            Опис: Кількість разів, яку можна використати код
            `-1` для безлімітного.
          threshold: |
            Підказка команди:
            Аргумент: [threshold]
            Опис: Мінімальна ціна, до якої можна застосувати код
            `-1` для безлімітного
          expired: |
            Підказка команди
            Аргумент: [expired]
            Опис: Час закінчення дії коду.
            `-1` для безлімітного терміну.
            Приймає як час Zulu, так і час епохи UNIX у секундах.
            Приклад Zulu: 2022-12-17T10:31:37Z
            Приклад UNIX: 1671273097
